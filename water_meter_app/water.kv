#:kivy 2.0.0
#:import dp kivy.metrics.dp

<MainScreen>:
    rv: rv
    days_input: days_input
    status_spinner: status_spinner
    page_input: page_input
    page_info: page_info
    status_label: status_label

    BoxLayout:
        orientation: 'vertical'

        # 顶部标题栏
        ActionBar:
            size_hint_y: None
            height: dp(56)
            ActionView:
                ActionPrevious:
                    title: '水表监控'
                    with_previous: False
                ActionOverflow:
                    ActionButton:
                        text: '设置Token'
                        on_press: root.show_token_popup()
                ActionButton:
                    id: token_indicator
                    text: '○'
                    color: 1, 0, 0, 1
                    size_hint_x: None
                    width: dp(40)

        # 参数筛选栏
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            spacing: dp(8)
            padding: dp(8)
            TextInput:
                id: days_input
                text: '30'
                hint_text: '未报天数'
                size_hint_x: 0.3
                input_filter: 'int'
            Spinner:
                id: status_spinner
                text: '启用'
                values: ['启用', '全部', '禁用']
                size_hint_x: 0.3
            Button:
                text: '抓取'
                size_hint_x: 0.3
                on_press: root.fetch_data()

        # 数据列表
        RecycleView:
            id: rv
            viewclass: 'WaterRecordRow'
            data: []
            RecycleBoxLayout:
                default_size: None, dp(50)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(2)

        # 分页和操作栏
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(4)
            padding: dp(8)
            Button:
                text: '上一页'
                on_press: root.prev_page()
            TextInput:
                id: page_input
                text: '1'
                size_hint_x: 0.15
                input_filter: 'int'
                multiline: False
                on_text_validate: root.jump_page()
            Button:
                text: '跳转'
                on_press: root.jump_page()
            Label:
                id: page_info
                text: '共 0 页 0 条'
                size_hint_x: 0.5
                halign: 'center'
            Button:
                text: '导出'
                on_press: root.export_csv()

        # 状态栏
        Label:
            id: status_label
            text: '就绪'
            size_hint_y: None
            height: dp(30)
            color: 0, 1, 0, 1
            text_size: self.size
            halign: 'center'


<WaterRecordRow>:
    BoxLayout:
        orientation: 'horizontal'
        padding: dp(4)
        size_hint_y: None
        height: dp(48)

        Label:
            text: root.cusName
            size_hint_x: 0.2
            halign: 'center'
        Label:
            text: root.usersNo
            size_hint_x: 0.15
            halign: 'center'
        Label:
            text: root.balance
            size_hint_x: 0.15
            halign: 'center'
        Label:
            text: root.valveState
            size_hint_x: 0.15
            halign: 'center'
        Label:
            text: root.receiveTime
            size_hint_x: 0.35
            halign: 'center'


<DetailScreen>:
    BoxLayout:
        orientation: 'vertical'
        ActionBar:
            ActionView:
                ActionPrevious:
                    title: '客户详情'
                    with_previous: True
                    on_press: app.root.current = 'main'
        ScrollView:
            Label:
                text: root.detail_text
                text_size: self.width - dp(20), None
                size_hint_y: None
                height: self.texture_size[1]
                padding: dp(10), dp(10)
                halign: 'left'
                valign: 'top'