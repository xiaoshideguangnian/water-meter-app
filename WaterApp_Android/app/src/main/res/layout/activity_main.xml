<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <!-- 工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">
        <TextView android:text="TabID:" />
        <EditText android:id="@+id/et_tabid" android:layout_width="80dp"
            android:inputType="number"/>
        <Button android:id="@+id/btn_refresh" android:text="刷新"
            style="?android:attr/buttonBarButtonStyle"/>
        <Button android:id="@+id/btn_export_csv" android:text="CSV"
            style="?android:attr/buttonBarButtonStyle"/>
        <Button android:id="@+id/btn_export_excel" android:text="Excel"
            style="?android:attr/buttonBarButtonStyle"/>
        <Button android:id="@+id/btn_logout" android:text="退出"
            android:textColor="#E65341"/>
    </LinearLayout>
    <!-- 表格区域（横向+纵向滚动） -->
    <HorizontalScrollView android:id="@+id/scroll_horizontal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ScrollView android:id="@+id/scroll_vertical"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">
            <TableLayout android:id="@+id/table_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:stretchColumns="0"/>
        </ScrollView>
    </HorizontalScrollView>
    <!-- 状态栏 -->
    <TextView android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="4dp"/>
    <!-- 日志面板（可折叠） -->
    <Button android:id="@+id/btn_toggle_log" android:text="展开日志"/>
    <LinearLayout android:id="@+id/log_panel"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:visibility="gone">
        <LinearLayout android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <Button android:id="@+id/btn_copy_log" android:text="复制日志"/>
            <Button android:id="@+id/btn_clear_log" android:text="清除"/>
        </LinearLayout>
        <ScrollView android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView android:id="@+id/tv_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:fontFamily="monospace"/>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
